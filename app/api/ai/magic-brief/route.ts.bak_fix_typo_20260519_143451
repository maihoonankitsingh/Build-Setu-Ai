import { NextResponse } from "next/server";
import { prisma } from "@/lib/db";

function cleanText(value: unknown) {
  if (typeof value !== "string") return "";
  return value.trim();
}

function includesAny(text: string, words: string[]) {
  const lower = text.toLowerCase();
  return words.some((word) => lower.includes(word.toLowerCase()));
}

function detectProjectType(brief: string) {
  if (includesAny(brief, ["shop", "showroom", "commercial", "office", "cafe", "restaurant"])) {
    return "Commercial / Mixed Use";
  }

  if (includesAny(brief, ["flat", "apartment", "room", "living", "bedroom", "kitchen interior", "interior"])) {
    return "Interior Design";
  }

  if (includesAny(brief, ["house", "ghar", "plot", "duplex", "villa", "g+1", "g+2"])) {
    return "Residential House";
  }

  return "Design + Construction Project";
}

function extractPlotSize(brief: string) {
  const match = brief.match(/\b(\d{2,3})\s*[xX×]\s*(\d{2,3})\b/);
  if (!match) return null;
  return `${match[1]}x${match[2]} ft`;
}

function detectFacing(brief: string) {
  const lower = brief.toLowerCase();
  if (lower.includes("north")) return "North";
  if (lower.includes("south")) return "South";
  if (lower.includes("east")) return "East";
  if (lower.includes("west")) return "West";
  return null;
}

function detectBudget(brief: string) {
  const lakhMatch = brief.match(/(\d+(?:\.\d+)?)\s*(lakh|lac|lakhs)/i);
  if (lakhMatch) return `${lakhMatch[1]} lakh`;

  const croreMatch = brief.match(/(\d+(?:\.\d+)?)\s*(crore|cr)/i);
  if (croreMatch) return `${croreMatch[1]} crore`;

  return null;
}

function detectFloors(brief: string) {
  const lower = brief.toLowerCase();
  if (lower.includes("g+3")) return "G+3";
  if (lower.includes("g+2")) return "G+2";
  if (lower.includes("g+1")) return "G+1";
  if (lower.includes("ground") && lower.includes("first")) return "G+1";
  if (lower.includes("ground")) return "Ground Floor";
  return null;
}

function detectOutputs(brief: string) {
  const outputs: string[] = [];

  if (includesAny(brief, ["interior", "living", "bedroom", "kitchen", "render"])) outputs.push("Interior Render");
  if (includesAny(brief, ["elevation", "facade", "front"])) outputs.push("Exterior Elevation");
  if (includesAny(brief, ["plan", "floor plan", "naksha", "nakssa", "layout"])) outputs.push("Floor Plan Concept");
  if (includesAny(brief, ["boq", "estimate", "budget", "cost"])) outputs.push("BOQ / Estimate");
  if (includesAny(brief, ["bbs", "bar bending", "steel"])) outputs.push("BBS Draft");
  if (includesAny(brief, ["agreement", "contract", "terms"])) outputs.push("Client Agreement");
  if (includesAny(brief, ["pdf", "proposal", "client"])) outputs.push("Client PDF");

  if (!outputs.length) {
    outputs.push("Magic Brief", "Interior Render", "Client PDF");
  }

  return Array.from(new Set(outputs));
}

function detectRooms(brief: string) {
  const roomMap = [
    ["parking", "Parking"],
    ["living", "Living Room"],
    ["kitchen", "Kitchen"],
    ["mandir", "Mandir"],
    ["bedroom", "Bedroom"],
    ["toilet", "Toilet"],
    ["bathroom", "Bathroom"],
    ["balcony", "Balcony"],
    ["staircase", "Staircase"],
    ["office", "Office"],
    ["shop", "Shop"],
    ["showroom", "Showroom"],
  ];

  return roomMap
    .filter(([keyword]) => brief.toLowerCase().includes(keyword))
    .map(([, label]) => label);
}

function buildQuestions(brief: string) {
  const questions: string[] = [];

  if (!detectPlotSize(brief)) questions.push("Plot size kya hai? Example: 30x40 ft.");
  if (!detectFacing(brief)) questions.push("Plot/road facing direction kya hai? North, South, East ya West?");
  if (!detectFloors(brief)) questions.push("Kitne floors chahiye? Ground only, G+1, G+2?");
  if (!detectBudget(brief)) questions.push("Approx budget range kya hai?");
  if (!includesAny(brief, ["city", "raipur", "bhilai", "indore", "delhi", "mumbai", "pune", "bangalore"])) {
    questions.push("Project city/location kya hai?");
  }

  questions.push("Vastu follow karna hai ya flexible layout chalega?");
  questions.push("Pehle output me kya chahiye: render, floor plan, BOQ, BBS, agreement ya client PDF?");

  return questions.slice(0, 7);
}

export async function POST(request: Request) {
  try {
    const body = await request.json().catch(() => null);

    if (!body || typeof body !== "object") {
      return NextResponse.json(
        { ok: false, error: "Invalid JSON body" },
        { status: 400 },
      );
    }

    const rawBrief = cleanText(body.rawBrief);

    if (!rawBrief) {
      return NextResponse.json(
        { ok: false, error: "rawBrief is required" },
        { status: 400 },
      );
    }

    const projectId = cleanText(body.projectId);

    const structuredBrief = {
      projectType: detectProjectType(rawBrief),
      plotSize: extractPlotSize(rawBrief),
      facing: detectFacing(rawBrief),
      floors: detectFloors(rawBrief),
      budget: detectBudget(rawBrief),
      detectedRooms: detectRooms(rawBrief),
      priorityOutputs: detectOutputs(rawBrief),
      safetyNotes: [
        "AI output planning and discussion ke liye draft hai.",
        "Final construction, structural, BOQ, BBS, MEP and legal documents professional review ke baad use karein.",
      ],
    };

    const questions = buildQuestions(rawBrief);

    let project = null;

    if (projectId) {
      project = await prisma.project.update({
        where: { id: projectId },
        data: {
          projectType: structuredBrief.projectType,
          plotSize: structuredBrief.plotSize || undefined,
          facing: structuredBrief.facing || undefined,
          floors: structuredBrief.floors || undefined,
          budget: structuredBrief.budget || undefined,
          brief: {
            upsert: {
              create: {
                rawBrief,
                structuredJson: JSON.stringify(structuredBrief),
                questionsJson: JSON.stringify(questions),
              },
              update: {
                rawBrief,
                structuredJson: JSON.stringify(structuredBrief),
                questionsJson: JSON.stringify(questions),
              },
            },
          },
          toolRuns: {
            create: {
              toolType: "MAGIC_BRIEF",
              inputJson: JSON.stringify({ rawBrief }),
              outputJson: JSON.stringify({ structuredBrief, questions }),
              creditsUsed: 1,
              status: "COMPLETED",
            },
          },
        },
        include: {
          brief: true,
          toolRuns: {
            take: 3,
            orderBy: { createdAt: "desc" },
          },
        },
      });
    }

    return NextResponse.json({
      ok: true,
      structuredBrief,
      questions,
      project,
    });
  } catch (error) {
    console.error("MAGIC_BRIEF_ERROR", error);

    return NextResponse.json(
      { ok: false, error: "Failed to generate magic brief" },
      { status: 500 },
    );
  }
}
