# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
prisma/dev.db
*.bak_*
app.bak_*
lib.bak_*
public/generated/renders/*
!public/generated/renders/.gitkeep
public/generated/agreements/*
!public/generated/agreements/.gitkeep

# Generated BuildSetu report PDFs
public/generated/reports/*
!public/generated/reports/.gitkeep

# BuildSetu local auth runtime data
data/buildsetu-auth-users.json
data/buildsetu-auth-sessions.json
data/buildsetu-auth-otps.json

# BuildSetu billing runtime data
data/buildsetu-billing-orders.json
data/buildsetu-credit-history.json
data/runtime/book-demo-leads.json
data/generated/user-profile-photos.json

# ===== BuildSetu runtime / backup ignore rules =====
# Local safety backups created by terminal patch phases
_safe_backups/

# Runtime logs, metering, and generated usage summaries
data/agent-usage/

# Runtime uploads and smoke-test uploaded files
data/agent-knowledge/uploads/
data/agent-knowledge-uploads/

# Generated AI/image/model output artifacts
data/generated/ai-images/
data/generated/model-renders/
data/generated/models/
public/generated/

# Temporary handoff/smoke artifacts
buildsetu_ai_logo.zip
*.bak
*.bak_*
*.tmp
*.log

# Local snapshots/reports should stay outside repo, but guard anyway
buildsetu-final-snapshots/

# ===== BuildSetu local runtime data - Phase 15B =====
# Keep canonical knowledge/training JSON tracked, but ignore live runtime state.
data/agent-feedback/
data/agent-knowledge/
data/buildsetu-research/

# Runtime generated workspace/project state.
data/generated/*.json
data/generated/*.png
data/generated/*.jpg
data/generated/*.jpeg
data/generated/*.webp
data/generated/*.svg
data/generated/*.mp4
data/generated/*.wav

# Keep canonical generated seed/master files tracked.
!data/generated/boq-rate-master.json

# Already tracked legacy runtime files are restored to HEAD and should not be recommitted.

# BUILDSETU_SOURCE_WATCH_RUNTIME
data/buildsetu-source-watch/state.json
data/buildsetu-source-watch/changes/
