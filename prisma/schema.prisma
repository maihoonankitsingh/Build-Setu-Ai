generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  DESIGNER
  ARCHITECT
  CONTRACTOR
  ENGINEER
  ADMIN
}

enum ProjectStatus {
  AI_DRAFT
  REVIEW_REQUIRED
  CLIENT_READY
  APPROVED
  ARCHIVED
}

enum ToolStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  REVIEW_REQUIRED
}

enum ToolType {
  MAGIC_BRIEF
  INTERIOR_RENDER
  EXTERIOR_ELEVATION
  RENDER_ENHANCER
  SITE_PHOTO_REDESIGN
  SKETCH_TO_PLAN
  FLOOR_PLAN_AI
  ARCHITECT_CHAT
  MOOD_BOARD
  REMOVE_FURNITURE
  BACKGROUND_CHANGE
  PHOTO_ENHANCER
  WORKING_DRAWINGS
  BOQ_GENERATOR
  BBS_GENERATOR
  COLUMN_BEAM_PLAN
  MATERIAL_PALETTE_AI
  FALSE_CEILING_AI
  VASTU_CHECK
  CLIENT_PDF
  CONTRACTOR_PACKAGE
  CLIENT_AGREEMENT
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  phone        String?
  role         UserRole @default(DESIGNER)
  credits      Int      @default(120)
  passwordHash String?
  status       String   @default("ACTIVE")
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects     Project[]
  creditLogs   CreditTransaction[]
  toolRuns     ToolRun[]
  auditLogs    AuditLog[]
  subscriptions PlanSubscription[]
  payments     Payment[]
}

model Project {
  id          String        @id @default(cuid())
  userId      String?
  title       String
  projectType String?
  location    String?
  plotSize    String?
  facing      String?
  floors      String?
  budget      String?
  status      ProjectStatus @default(AI_DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  brief       DesignBrief?
  renders     Render[]
  boqItems    BOQItem[]
  bbsItems    BBSItem[]
  agreements  ClientAgreement[]
  toolRuns    ToolRun[]
}

model DesignBrief {
  id             String   @id @default(cuid())
  projectId      String   @unique
  rawBrief       String
  structuredJson String?
  questionsJson  String?
  answersJson    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Render {
  id          String     @id @default(cuid())
  projectId   String
  renderType  String
  roomType    String?
  prompt      String
  imageUrl    String?
  version     Int        @default(1)
  status      ToolStatus @default(COMPLETED)
  createdAt   DateTime   @default(now())

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BOQItem {
  id          String   @id @default(cuid())
  projectId   String
  itemCode    String?
  description String
  unit        String?
  quantity    Float?
  rate        Float?
  amount      Float?
  drawingRef  String?
  status      String   @default("Draft")
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BBSItem {
  id            String   @id @default(cuid())
  projectId     String
  memberType    String
  memberId      String?
  barMark       String?
  diameter      Float?
  quantity      Int?
  shapeCode     String?
  cuttingLength Float?
  totalLength   Float?
  unitWeight    Float?
  totalWeight   Float?
  drawingRef    String?
  status        String   @default("AI Final Draft - Review Required")
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ClientAgreement {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  scope         String?
  deliverables  String?
  paymentTerms  String?
  revisionTerms String?
  disclaimer    String?
  status        String   @default("Draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ToolRun {
  id          String     @id @default(cuid())
  userId      String?
  projectId   String?
  toolType    ToolType
  inputJson   String?
  outputJson  String?
  creditsUsed Int        @default(0)
  status      ToolStatus @default(COMPLETED)
  createdAt   DateTime   @default(now())

  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String?
  projectId   String?
  actionType  String
  creditsUsed Int
  note        String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Payment {
  id                String   @id @default(cuid())
  userId            String?
  provider          String   @default("RAZORPAY")
  type              String
  itemId            String?
  itemName          String?
  amount            Int
  currency          String   @default("INR")
  credits           Int      @default(0)
  status            String   @default("CREATED")
  providerOrderId   String?  @unique
  providerPaymentId String?  @unique
  receipt           String?
  rawJson           String?
  createdAt         DateTime @default(now())
  verifiedAt        DateTime?
  updatedAt         DateTime @updatedAt

  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PlanSubscription {
  id                String   @id @default(cuid())
  userId            String
  planId            String
  planName          String
  interval          String
  amount            Int
  credits           Int
  status            String   @default("ACTIVE")
  provider          String   @default("RAZORPAY")
  providerOrderId   String?
  providerPaymentId String?
  startedAt         DateTime @default(now())
  renewsAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String?
  entityId    String?
  metadataJson String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}



model BookDemoLead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String   @default("")
  company     String   @default("")
  role        String   @default("")
  projectType String   @default("")
  requirement String   @default("")
  source      String   @default("book-demo")
  status      String   @default("NEW")
  ipAddress   String   @default("")
  userAgent   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
